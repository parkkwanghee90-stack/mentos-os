NAVER_ID=아이디
NAVER_PW=비밀번호
NAVER_CAFE_URL=https://cafe.naver.com/subit
NAVER_HEADLESS=false
NAVER_START_PAGE=1
NAVER_END_PAGE=3

# 구글 제미나이 2.5 보이스 API 연동 (밝은 여성 목소리 Aoede 적용)
# 발급 사이트: https://aistudio.google.com/
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================
#  Supabase (필수) — 클라이언트에는 anon(public) 키만 사용할 것.
#  service_role 등 권한 키는 절대 넣지 마세요 (RLS 우회 → DB 전체 노출).
# ============================================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_public_key

# ============================================================
#  관리자 인증
# ============================================================
# 관리자 코드 인증용 시크릿. 비워두면 관리자 코드 승격이 비활성화됩니다.
VITE_ADMIN_SECRET=
# 통합관리자 슈퍼패스 인증번호. 비워두면 슈퍼패스 우회가 비활성화됩니다(안전 기본값).
VITE_SUPER_PASS=
