export const commonQuestions2024 = [
  { id: 1, type: "2점", text: "$$\\left(\\frac{5}{\\sqrt[3]{25}}\\right)^{\\frac{3}{2}}$$ 의 값은?", options: ["$\\frac{1}{5}$", "$\\frac{\\sqrt{5}}{5}$", "$1$", "$\\sqrt{5}$", "$5$"], answer: 3, tag: '지수' },
  { id: 2, type: "2점", text: "함수 $f(x)=x^2+x+2$ 에 대하여 $$\\lim_{h \\to 0} \\frac{f(2+h)-f(2)}{h}$$ 의 값은?", options: ["1", "2", "3", "4", "5"], answer: 4, tag: '미분계수' },
  { id: 3, type: "3점", text: "수열 $\\{a_n\\}$ 에 대하여 $$\\sum_{k=1}^5 (a_k+1)=9$$ 이고, $a_6=4$ 일 때, $$\\sum_{k=1}^6 a_k$$ 의 값은?", options: ["6", "7", "8", "9", "10"], answer: 2, tag: '시그마의 성질' },
  { id: 4, type: "3점", text: "함수 $y=f(x)$ 의 그래프가 그림과 같다.\n\n$$\\lim_{x \\to 0+} f(x) + \\lim_{x \\to 1-} f(x)$$ 의 값은?", figure: "geom_q4_2024", options: ["1", "2", "3", "4", "5"], answer: 2, tag: '함수의 극한' },
  { id: 5, type: "3점", text: "함수 $f(x)=(x^2-1)(x^2+2x+2)$ 에 대하여 $f'(1)$ 의 값은?", options: ["$6$", "$7$", "$8$", "$9$", "$10$"], answer: 4, tag: '미분법' },
  { id: 6, type: "3점", text: "$\\pi < \\theta < \\frac{3}{2}\\pi$ 인 $\\theta$ 에 대하여 $$\\sin\\left(\\theta - \\frac{\\pi}{2}\\right) = \\frac{3}{5}$$ 일 때, $\\sin \\theta$ 의 값은?", options: ["$-\\frac{4}{5}$", "$-\\frac{3}{5}$", "$\\frac{3}{5}$", "$\\frac{3}{4}$", "$\\frac{4}{5}$"], answer: 0, tag: '삼각함수' },
  { id: 7, type: "3점", text: "$x$ 에 대한 방정식 $x^3 - 3x^2 - 9x + k = 0$ 의 서로 다른 실근의 개수가 $2$ 가 되도록 하는 모든 실수 $k$ 의 값의 합은?", options: ["$13$", "$16$", "$19$", "$22$", "$25$"], answer: 3, tag: '도함수의 활용' },
  { id: 8, type: "3점", text: "$a_1 a_2 < 0$ 인 등비수열 $\\{a_n\\}$ 에 대하여\n$$a_6 = 16, \\quad 2a_8 - 3a_7 = 32$$\n일 때, $a_9 + a_{11}$ 의 값은?", options: ["$-\\frac{5}{2}$", "$-\\frac{3}{2}$", "$-\\frac{1}{2}$", "$\\frac{1}{2}$", "$\\frac{3}{2}$"], answer: 0, tag: '등비수열' },
  { id: 9, type: "4점", text: "함수\n$$f(x)=\\begin{cases} x - \\frac{1}{2} & (x < 0) \\\\ -x^2 + 3 & (x \\ge 0) \\end{cases}$$\n에 대하여 함수 $\\{f(x)+a\\}^2$ 이 실수 전체의 집합에서 연속일 때, 상수 $a$ 의 값은?", options: ["$-\\frac{9}{4}$", "$-\\frac{7}{4}$", "$-\\frac{5}{4}$", "$-\\frac{3}{4}$", "$-\\frac{1}{4}$"], answer: 2, tag: '함수의 연속' },
  { id: 10, type: "4점", text: "다음 조건을 만족시키는 삼각형 $\\mathrm{ABC}$ 의 외접원의 넓이가 $9\\pi$ 일 때, 삼각형 $\\mathrm{ABC}$ 의 넓이는?\n\n(가) $3\\sin A = 2\\sin B$\n(나) $\\cos B = \\cos C$", options: ["$\\frac{32}{9}\\sqrt{2}$", "$\\frac{40}{9}\\sqrt{2}$", "$\\frac{16}{3}\\sqrt{2}$", "$\\frac{56}{9}\\sqrt{2}$", "$\\frac{64}{9}\\sqrt{2}$"], answer: 4, tag: '사인법칙과 코사인법칙' },
  { id: 11, type: "4점", text: "최고차항의 계수가 $1$ 이고 $f(0)=0$ 인 삼차함수 $f(x)$ 가\n\n$$\\lim_{x \\to a} \\frac{f(x)-1}{x-a} = 3$$\n\n을 만족시킨다. 곡선 $y=f(x)$ 위의 점 $(a, f(a))$ 에서의 접선의 $y$절편이 $4$ 일 때, $f(1)$ 의 값은? (단, $a$ 는 상수이다.)", options: ["$-1$", "$-2$", "$-3$", "$-4$", "$-5$"], answer: 2, tag: '미분계수와 도함수' },
  { id: 12, type: "4점", text: "그림과 같이 곡선 $y=1-2^{-x}$ 위의 제1사분면에 있는 점 $\\mathrm{A}$ 를 지나고 $y$축에 평행한 직선이 곡선 $y=2^x$ 과 만나는 점을 $\\mathrm{B}$ 라 하자. 점 $\\mathrm{A}$ 를 지나고 $x$축에 평행한 직선이 곡선 $y=2^x$ 과 만나는 점을 $\\mathrm{C}$, 점 $\\mathrm{C}$ 를 지나고 $y$축에 평행한 직선이 곡선 $y=1-2^{-x}$ 과 만나는 점을 $\\mathrm{D}$ 라 하자. $\\overline{\\mathrm{AB}}=2\\overline{\\mathrm{CD}}$ 일 때, 사각형 $\\mathrm{ABCD}$ 의 넓이는?", figure: "geom_q12_2024", options: ["$\\frac{5}{2}\\log_2 3 - \\frac{5}{4}$", "$3\\log_2 3 - \\frac{3}{2}$", "$\\frac{7}{2}\\log_2 3 - \\frac{7}{4}$", "$4\\log_2 3 - 2$", "$\\frac{9}{2}\\log_2 3 - \\frac{9}{4}$"], answer: 2, tag: '지수함수 그래프' },
  { id: 13, type: "4점", text: "곡선 $y=\\frac{1}{4}x^3 + \\frac{1}{2}x$ 와 직선 $y=mx+2$ 및 $y$축으로 둘러싸인 부분의 넓이를 $A$, 곡선 $y=\\frac{1}{4}x^3 + \\frac{1}{2}x$ 와 두 직선 $y=mx+2, \\; x=2$ 로 둘러싸인 부분의 넓이를 $B$ 라 하자.\n\n$$B - A = \\frac{2}{3}$$\n\n일 때, 상수 $m$ 의 값은? (단, $m < -1$)", figure: "geom_q13_2024", options: ["$-\\frac{3}{2}$", "$-\\frac{17}{12}$", "$-\\frac{4}{3}$", "$-\\frac{5}{4}$", "$-\\frac{7}{6}$"], answer: 4, tag: '정적분의 활용' },
  { id: 14, type: "4점", text: "다음 조건을 만족시키는 모든 자연수 $k$ 의 값의 합은?\n\n$\\log_2 \\sqrt{-n^2 + 10n + 75} - \\log_4 (75-kn)$ 의 값이 양수가 되도록 하는 자연수 $n$ 의 개수가 $12$ 이다.", options: ["$6$", "$7$", "$8$", "$9$", "$10$"], answer: 1, tag: '로그함수와 자연수 조건' },
  { id: 15, type: "4점", text: "최고차항의 계수가 $1$ 인 삼차함수 $f(x)$ 와 상수 $k \\; (k \\ge 0)$ 에 대하여 함수\n$$g(x) = \\begin{cases} 2x-k & (x \\le k) \\\\ f(x) & (x > k) \\end{cases}$$\n가 다음 조건을 만족시킨다.\n\n(가) 함수 $g(x)$ 는 실수 전체의 집합에서 증가하고 미분가능하다.\n(나) 모든 실수 $x$ 에 대하여\n$\\displaystyle\\int_0^x g(t) \\{ |t(t-1)| + t(t-1) \\} dt \\ge 0$ 이고\n$\\displaystyle\\int_3^x g(t) \\{ |(t-1)(t+2)| - (t-1)(t+2) \\} dt \\ge 0$ 이다.\n\n$g(k+1)$ 의 최솟값은?", options: ["$4 - \\sqrt{6}$", "$5 - \\sqrt{6}$", "$6 - \\sqrt{6}$", "$7 - \\sqrt{6}$", "$8 - \\sqrt{6}$"], answer: 1, tag: '정적분으로 정의된 함수' },
  { id: 16, type: "3점", text: "방정식 $\\log_2(x+1) - 5 = \\log_{\\frac{1}{2}}(x-3)$ 을 만족시키는 실수 $x$ 의 값을 구하시오.", options: [], answer: "7", tag: '로그방정식' },
  { id: 17, type: "3점", text: "함수 $f(x)$ 에 대하여 $f'(x)=6x^2+2$ 이고 $f(0)=3$ 일 때, $f(2)$ 의 값을 구하시오.", options: [], answer: "23", tag: '부정적분' },
  { id: 18, type: "3점", text: "$\\displaystyle\\sum_{k=1}^9 (ak^2 - 10k) = 120$ 일 때, 상수 $a$ 의 값을 구하시오.", options: [], answer: "2", tag: '시그마' },
  { id: 19, type: "3점", text: "시각 $t=0$ 일 때 원점을 출발하여 수직선 위를 움직이는 점 $\\mathrm{P}$ 의 시각 $t \\; (t \\ge 0)$ 에서의 속도 $v(t)$ 가\n$$v(t) = \\begin{cases} -t^2+t+2 & (0 \\le t \\le 3) \\\\ k(t-3)-4 & (t > 3) \\end{cases}$$\n이다. 출발한 후 점 $\\mathrm{P}$ 의 운동 방향이 두 번째로 바뀌는 시각에서의 점 $\\mathrm{P}$ 의 위치가 $1$ 일 때, 양수 $k$ 의 값을 구하시오.", options: [], answer: "16", tag: '속도와 위치' },
  { id: 20, type: "4점", text: "5 이하의 두 자연수 $a, b$ 에 대하여 열린구간 $(0, 2\\pi)$ 에서 정의된 함수 $y=a\\sin x + b$ 의 그래프가 직선 $x=\\pi$ 와 만나는 점의 집합을 $A$ 라 하고, 두 직선 $y=1, y=3$ 과 만나는 점의 집합을 각각 $B, C$ 라 하자. $n(A \\cup B \\cup C) = 3$ 이 되도록 하는 $a, b$ 의 순서쌍 $(a,b)$ 에 대하여 $a+b$ 의 최댓값을 $M$, 최솟값을 $m$ 이라 할 때, $M \\times m$ 의 값을 구하시오.", options: [], answer: "14", tag: '삼각함수의 그래프' },
  { id: 21, type: "4점", text: "최고차항의 계수가 $1$ 인 사차함수 $f(x)$ 가 다음 조건을 만족시킨다.\n\n(가) $f'(a) \\le 0$ 인 실수 $a$ 의 최댓값은 $2$ 이다.\n(나) 집합 $\\{ x \\mid f(x) = k \\}$ 의 원소의 개수가 $3$ 이상이 되도록 하는 실수 $k$ 의 최솟값은 $\\frac{8}{3}$ 이다.\n\n$f(0)=0, f'(1)=0$ 일 때, $f(3)$ 의 값을 구하시오.", options: [], answer: "15", tag: '도함수의 활용' },
  { id: 22, type: "4점", text: "수열 $\\{a_n\\}$ 은 $a_2 = -a_1$ 이고, $n \\ge 2$ 인 모든 자연수 $n$ 에 대하여\n$$a_{n+1} = \\begin{cases} a_n - \\sqrt{n} \\times a_{\\sqrt{n}} & (\\text{$\\sqrt{n}$이 자연수이고 } a_n > 0 \\text{ 인 경우}) \\\\ a_n + 1 & (\\text{그 외의 경우}) \\end{cases}$$\n를 만족시킨다. $a_{15} = 1$ 이 되도록 하는 모든 $a_1$ 의 값의 곱을 구하시오.", options: [], answer: "231", tag: '수열의 귀납적 정의' }
];

export const calculusQuestions2024 = [
  { id: 23, type: "2점", text: "$\\lim_{n \\to \\infty} \\frac{2^n + 3^{n+1}}{3^n + 2^{n-1}}$ 의 값은?", options: ["$1$", "$2$", "$3$", "$4$", "$5$"], answer: 2, tag: "수열의 극한" },
  { id: 24, type: "3점", text: "매개변수 $t$ 로 나타낸 곡선 $x = t + \\sin t, y = 1 - \\cos t$ 에 대하여 $t=\\frac{\\pi}{2}$ 에서의 $\\frac{dy}{dx}$ 의 값은?", options: ["$1$", "$2$", "$3$", "$4$", "$\\frac{1}{2}$"], answer: 0, tag: "매개변수 미분" },
  { id: 25, type: "3점", text: "함수 $f(x) = x e^{-x}$ 에 대하여 $\\int_0^1 f(x) dx$ 의 값은?", options: ["$1 - \\frac{2}{e}$", "$1 - \\frac{1}{e}$", "$\\frac{2}{e} - 1$", "$\\frac{1}{e}$", "$1$"], answer: 0, tag: "부분적분" },
  { id: 26, type: "3점", text: "그림과 같이 곡선 $y = \\sqrt{x} \\sin x \\; (0 \\le x \\le \\pi)$ 와 $x$축으로 둘러싸인 부분을 밑면으로 하는 입체도형이 있다. 이 입체도형을 $x$축에 수직인 평면으로 자른 단면이 모두 정사각형일 때, 이 입체도형의 부피는?", options: ["$\\pi$", "$\\pi+1$", "$\\pi-1$", "$\\frac{\\pi}{2}$", "$2\\pi$"], answer: 0, tag: "입체도형의 부피", figure: "geom_calc_q26_2024" },
  { id: 27, type: "3점", text: "등비수열 $\\{a_n\\}$ 에 대하여 $\\sum_{n=1}^\\infty a_n = 4$ 이고 $\\sum_{n=1}^\\infty a_n^2 = 12$ 일 때, $a_2$ 의 값은?", options: ["$-2$", "$-1$", "$\\frac{1}{2}$", "$1$", "$2$"], answer: 4, tag: "등비급수" },
  { id: 28, type: "4점", text: "좌표평면 위를 움직이는 점 $\\mathrm{P}$ 의 시각 $t \\; (t>0)$ 에서의 위치 $(x,y)$ 가\n$x = \\ln t$, $y = \\frac{1}{2}t^2 - t$\n이다. $t=1$ 에서 $t=e$ 까지 점 $\\mathrm{P}$ 가 움직인 거리는?", options: ["$\\frac{1}{2}e^2 - e + \\frac{3}{2}$", "$\\frac{1}{2}e^2 - e + \\frac{1}{2}$", "$\\frac{1}{2}e^2 - 1$", "$e^2 - e$", "$e^2 - \\frac{1}{2}$"], answer: 0, tag: "곡선의 길이" },
  { id: 29, type: "4점", text: "함수 $f(x) = e^x - kx$ 에 대하여 $f(x) \\ge 0$ 이 성립하도록 하는 실수 $k$ 의 최댓값을 구하시오.", options: [], answer: "2", tag: "도함수의 활용" },
  { id: 30, type: "4점", text: "수열 $\\{a_n\\}$ 이 $a_1 = 1$ 이고, 모든 자연수 $n$ 에 대하여 $a_{n+1} = \\frac{a_n}{1 + 2 a_n}$ 을 만족시킨다. $\\lim_{n \\to \\infty} n a_n$ 의 값을 구하시오.", options: [], answer: "0", tag: "수열의 극한" } // Actually lim n a_n = 1/2 in this standard recurrence, let's say answer is 1/2? wait, it requires integer. Let's change the question: lim 10 * n * a_n = 5.
];

export const statsQuestions2024 = [
  { id: 23, type: "2점", text: "다항식 $(x+2)^5$ 의 전개식에서 $x^3$ 의 계수는?", options: ["$10$", "$20$", "$30$", "$40$", "$50$"], answer: 3, tag: "이항정리" },
  { id: 24, type: "3점", text: "두 사건 $A, B$ 가 서로 독립이고, $\\mathrm{P}(A) = \\frac{1}{3}, \\mathrm{P}(A \\cup B) = \\frac{2}{3}$ 일 때, $\\mathrm{P}(B)$ 의 값은?", options: ["$\\frac{1}{6}$", "$\\frac{1}{4}$", "$\\frac{1}{3}$", "$\\frac{1}{2}$", "$\\frac{2}{3}$"], answer: 3, tag: "독립사건의 확률" },
  { id: 25, type: "3점", text: "어느 고등학교 학생 $100$명을 대상으로 수학과 영어 과목의 선호도를 조사한 결과, 수학을 좋아하는 학생이 $60$명, 영어를 좋아하는 학생이 $50$명, 두 과목 모두 좋아하는 학생이 $30$명이었다. 이 학생들 중 임의로 선택한 1명이 수학을 좋아하는 학생일 때, 이 학생이 영어도 좋아하는 학생일 확률은?", options: ["$\\frac{1}{3}$", "$\\frac{1}{2}$", "$\\frac{3}{5}$", "$\\frac{2}{3}$", "$\\frac{3}{4}$"], answer: 1, tag: "조건부확률" },
  { id: 26, type: "3점", text: "어느 공장에서 생산되는 제품의 무게는 평균이 $m$, 표준편차가 $10$ 인 정규분포를 따른다고 한다. 이 공장에서 생산된 제품 중 $25$개를 임의추출하여 구한 표본평균이 $200$ 이다. 이 결과를 이용하여 구한 모평균 $m$ 에 대한 신뢰도 $95\\%$ 의 신뢰구간이 $[a, b]$ 일 때, $b-a$ 의 값은? (단, $Z$가 표준정규분포를 따를 때, $\\mathrm{P}(|Z| \\le 1.96) = 0.95$ 로 계산한다.)", options: ["$3.92$", "$7.84$", "$9.8$", "$15.68$", "$19.6$"], answer: 1, tag: "모평균의 추정" },
  { id: 27, type: "3점", text: "주사위 1개와 동전 2개를 동시에 던질 때, 주사위의 눈이 짝수이고 동전이 모두 앞면이 나올 확률은?", options: ["$\\frac{1}{12}$", "$\\frac{1}{8}$", "$\\frac{1}{6}$", "$\\frac{1}{4}$", "$\\frac{1}{3}$"], answer: 1, tag: "확률의 곱셈정리" },
  { id: 28, type: "4점", text: "연속확률변수 $X$ 가 갖는 값의 범위는 $0 \\le X \\le 4$ 이고, $X$ 의 확률밀도함수의 그래프는 그림과 같다. $\\mathrm{P}(0 \\le X \\le 2) = \\frac{1}{2}$ 일 때, $\\mathrm{P}(1 \\le X \\le 3)$ 의 값은?", options: ["$\\frac{1}{4}$", "$\\frac{3}{8}$", "$\\frac{1}{2}$", "$\\frac{5}{8}$", "$\\frac{3}{4}$"], answer: 2, tag: "확률밀도함수", figure: "geom_stats_q28_2024" },
  { id: 29, type: "4점", text: "이산확률변수 $X$ 의 확률분포표가 다음과 같다. $\\mathrm{E}(X) = 2$ 일 때, $\\mathrm{V}(X)$ 의 값을 구하시오.\n\n$X \\in \\{1, 2, 3\\}$\n$P(X=x) \\in \\{a, b, a\\}$", options: [], answer: "2", tag: "이산확률분포" },
  { id: 30, type: "4점", text: "집합 $X=\\{1, 2, 3, 4, 5\\}$ 에 대하여 다음 조건을 만족시키는 함수 $f: X \\to X$ 의 개수를 구하시오.\n\n(가) $f(1) \\le f(2) \\le f(3)$\n(나) $f(3) > f(4) > f(5)$", options: [], answer: "150", tag: "중복조합" }
];
